<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/coffee_brown"
        android:elevation="6dp"
        android:layout_marginBottom="16dp"
        android:clipToOutline="true">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_inventory"
            android:contentDescription="Inventory Icon"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvInventoryHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inventory"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage your product stocks and supplies"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:alpha="0.9"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Add Product Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAddInventory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_add_product"
                android:contentDescription="Add Product Icon"
                android:tint="@color/coffee_dark_brown"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Add New Product"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/coffee_dark_brown"/>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_coffee_arrow"
                android:tint="@color/coffee_dark_brown"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- RecyclerView for Inventory Items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerInventory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="vertical"
        android:overScrollMode="always"/>
</LinearLayout>
